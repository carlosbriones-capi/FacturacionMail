<Window x:Class="FacturacionMail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FacturacionMail.Views"
        Title="Facturas — Impresión y Envíos Mail"
        MinWidth="900" MinHeight="600"
        Width="1150" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <DockPanel>
        <!-- ── Barra de título corporativa ── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource HeaderGradientBrush}"
                Height="56"
                Padding="24,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="18" Foreground="White" Margin="0,0,12,0"/>
                    <TextBlock Text="FACTURAEMAIL"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontWeight="Bold"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="#4DFFFFFF" Margin="16,0"/>
                    <TextBlock Text="Impresión y Envíos Mail"
                               Foreground="{StaticResource TextOnPrimaryMutedBrush}"
                               FontFamily="Segoe UI"
                               FontWeight="Light"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='Fecha: {0:dd/MM/yyyy}'}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"
                           Foreground="{StaticResource TextOnPrimaryMutedBrush}"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ── Menú Moderno ── -->
        <Menu DockPanel.Dock="Top"
              Style="{StaticResource ModernMenuStyle}"
              BorderBrush="{StaticResource BorderLightBrush}"
              BorderThickness="0,0,0,1">
            
            <MenuItem Header="Estado" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem Header="Conexión BD" Style="{StaticResource ModernMenuItemStyle}"/>
                <MenuItem Header="Servidor de correo" Style="{StaticResource ModernMenuItemStyle}"/>
                <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                <MenuItem Header="Acerca de..." Style="{StaticResource ModernMenuItemStyle}"/>
            </MenuItem>
            
            <MenuItem Header="Órdenes" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem Header="Procesar selección" Style="{StaticResource ModernMenuItemStyle}"/>
                <MenuItem Header="Enviar mail" Style="{StaticResource ModernMenuItemStyle}"/>
                <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                <MenuItem Header="Limpiar criterios" Style="{StaticResource ModernMenuItemStyle}"/>
            </MenuItem>
            
            <MenuItem Header="Ver" Style="{StaticResource ModernMenuItemStyle}">
                <MenuItem Header="Consulta de facturas" Click="OnConsultaFacturasClick" Style="{StaticResource ModernMenuItemStyle}" IsChecked="True"/>
                <MenuItem Header="Envío Facturación Mail" Click="OnEnvioMailClick" Style="{StaticResource ModernMenuItemStyle}"/>
                <MenuItem Header="Facturas Pendientes" Click="OnFacturasPendientesClick" Style="{StaticResource ModernMenuItemStyle}"/>
                <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                <MenuItem Header="Clientes excluidos" Style="{StaticResource ModernMenuItemStyle}"/>
            </MenuItem>
        </Menu>

        <!-- ── Barra de estado inferior ── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource SurfaceAltBrush}"
                   BorderBrush="{StaticResource BorderLightBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="FACTURAEMAIL — CM Capital Markets · Ochandiano, 2 · 28023 Madrid"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:HH:mm}'}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Contenido principal ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentControl x:Name="MainContent">
                <views:ConsultaFacturasView/>
            </ContentControl>
        </ScrollViewer>
    </DockPanel>
</Window>
