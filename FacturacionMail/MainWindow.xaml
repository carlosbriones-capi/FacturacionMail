<Window x:Class="FacturacionMail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:views="clr-namespace:FacturacionMail.Views"
        xmlns:local="clr-namespace:FacturacionMail"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d" 
        Background="{StaticResource AppBackgroundBrush}"
        Title="Facturas — Envíos Mail"
        MinWidth="900" MinHeight="600"
        Width="1150" Height="760"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <DockPanel>
        <!-- ── Nav Bar Unificada (Brand + Menú + Acciones) ── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource HeaderGradientBrush}"
                Height="68"
                Padding="28,0"
                BorderThickness="0">
            <!-- Sombra interior en la parte inferior para dar profundidad sutil a la barra -->
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.15" ShadowDepth="3" Direction="270" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Brand -->
                    <ColumnDefinition Width="32"/>   <!-- Spacer -->
                    <ColumnDefinition Width="*"/>    <!-- Menu Navigation -->
                    <ColumnDefinition Width="Auto"/> <!-- Actions/Date -->
                </Grid.ColumnDefinitions>

                <!-- Brand / Logo Area -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource SurfaceBrush}" 
                            Width="36" Height="36" 
                            CornerRadius="8" 
                            Margin="0,0,12,0">
                        <TextBlock Text="📄" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="18" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="FACTURA" 
                               FontFamily="{StaticResource HeaderFontFamily}" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource TextOnPrimaryBrush}" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text="EMAIL" 
                               FontFamily="{StaticResource HeaderFontFamily}" 
                               FontSize="18" FontWeight="Light" 
                               Foreground="{StaticResource TextOnPrimaryMutedBrush}" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Menú de Navegación integrado -->
                <Menu Grid.Column="2"
                      Style="{StaticResource HeaderMenuStyle}"
                      VerticalAlignment="Center">
                      <Menu.ItemsPanel>
                          <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal"/>
                          </ItemsPanelTemplate>
                      </Menu.ItemsPanel>
                    
                    <MenuItem x:Name="MenuConsulta" Click="OnConsultaFacturasClick" Style="{StaticResource HeaderMenuItemStyle}" IsCheckable="True" IsChecked="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="15" Margin="0,0,10,0" FontWeight="Normal" VerticalAlignment="Center"/>
                                <TextBlock Text="Consulta" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
        
                    <MenuItem x:Name="MenuEnvio" Click="OnEnvioMailClick" Style="{StaticResource HeaderMenuItemStyle}" IsCheckable="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✉" FontSize="15" Margin="0,0,10,0" FontWeight="Normal" VerticalAlignment="Center"/>
                                <TextBlock Text="Envíos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
        
                    <MenuItem x:Name="MenuPendientes" Click="OnFacturasPendientesClick" Style="{StaticResource HeaderMenuItemStyle}" IsCheckable="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,10,0" FontWeight="Normal" VerticalAlignment="Center"/>
                                <TextBlock Text="Pendientes" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
        
                    <MenuItem x:Name="MenuEstado" Click="OnEstadoEnviosClick" Style="{StaticResource HeaderMenuItemStyle}" IsCheckable="True">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0" FontWeight="Normal" VerticalAlignment="Center"/>
                                <TextBlock Text="Estado" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </Menu>

                <!-- Acciones / Herramientas -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:dd MMM yyyy}'}"
                                   xmlns:sys="clr-namespace:System;assembly=mscorlib"
                                   Foreground="{StaticResource TextOnPrimaryMutedBrush}"
                                   FontFamily="{StaticResource HeaderFontFamily}"
                                   FontWeight="Medium"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Barra de estado inferior ── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource SurfaceAltBrush}"
                   BorderBrush="{StaticResource BorderLightBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock FontFamily="{StaticResource MainFontFamily}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="FACTURAEMAIL — CM Capital Markets · Ochandiano, 2 · 28023 Madrid"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock FontFamily="{StaticResource MainFontFamily}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:HH:mm}'}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Contenido principal ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentControl x:Name="MainContent">
                <views:ConsultaFacturasView/>
            </ContentControl>
        </ScrollViewer>
        </DockPanel>

        <!-- ── VENTANA MODAL GLOBAL DE ESTADO ── -->
        <Border Background="#99000000" 
                Visibility="{Binding Content.DataContext.IsModalVisible, ElementName=MainContent, Converter={StaticResource BoolToVis}}"
                d:Visibility="Collapsed">
            <ContentControl Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Style="{StaticResource CardStyle}" Padding="32">
                <ContentControl.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.4" ShadowDepth="10"/>
                </ContentControl.Effect>
                
                <StackPanel>
                    <!-- Ícono Dinámico -->
                    <Grid Width="70" Height="70" Margin="0,0,0,24">
                        <Ellipse x:Name="IconBg">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource PrimaryLightBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Loading">
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Success">
                                            <Setter Property="Fill" Value="#2F855A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Error">
                                            <Setter Property="Fill" Value="#C53030"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock x:Name="IconText" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="32" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE72C;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Loading">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RotateAction">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RotateAction"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Success">
                                            <Setter Property="Text" Value="&#xE73E;"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Error">
                                            <Setter Property="Text" Value="&#xEA39;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Título y Mensaje -->
                    <TextBlock Text="{Binding Content.DataContext.ModalTitle, ElementName=MainContent}" 
                               FontFamily="{StaticResource HeaderFontFamily}" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               TextAlignment="Center"/>
                    
                    <TextBlock Text="{Binding Content.DataContext.ModalMessage, ElementName=MainContent}" 
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" 
                               TextWrapping="Wrap" Margin="0,0,0,24"/>

                    <!-- Botón Cerrar (Solo para Error) -->
                    <Button x:Name="CloseButton" 
                            Content="Entendido" 
                            Command="{Binding Content.DataContext.CerrarModalCommand, ElementName=MainContent}"
                            HorizontalAlignment="Center" Padding="40,10">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Content.DataContext.ModalType, ElementName=MainContent}" Value="Error">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </ContentControl>
        </Border>
    </Grid>
</Window>
