<Window x:Class="FacturacionMail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FacturacionMail.Views"
        Title="Facturas — Impresión y Envíos Mail"
        MinWidth="900" MinHeight="600"
        Width="1150" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">

    <DockPanel>
        <!-- ── Barra de título corporativa ── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource HeaderGradientBrush}"
                Height="56"
                Padding="24,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="18" Foreground="White" Margin="0,0,12,0"/>
                    <TextBlock Text="FACTURAEMAIL"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontWeight="Bold"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="#4DFFFFFF" Margin="16,0"/>
                    <TextBlock Text="Impresión y Envíos Mail"
                               Foreground="{StaticResource TextOnPrimaryMutedBrush}"
                               FontFamily="Segoe UI"
                               FontWeight="Light"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='Fecha: {0:dd/MM/yyyy}'}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"
                           Foreground="{StaticResource TextOnPrimaryMutedBrush}"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ── Menú Moderno ── -->
        <Menu DockPanel.Dock="Top"
              Style="{StaticResource ModernMenuStyle}"
              BorderBrush="{StaticResource BorderLightBrush}"
              BorderThickness="0,0,0,1">
            
            <MenuItem x:Name="MenuConsulta" Click="OnConsultaFacturasClick" Style="{StaticResource ModernMenuItemStyle}" IsCheckable="True" IsChecked="True">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Consulta Facturas" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem x:Name="MenuEnvio" Click="OnEnvioMailClick" Style="{StaticResource ModernMenuItemStyle}" IsCheckable="True">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✉" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Envío Facturación" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem x:Name="MenuPendientes" Click="OnFacturasPendientesClick" Style="{StaticResource ModernMenuItemStyle}" IsCheckable="True">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📨" FontSize="16" FontFamily="Segoe UI Emoji" Margin="0,-4,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Factur. Pendientes" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem x:Name="MenuEstado" Click="OnEstadoEnviosClick" Style="{StaticResource ModernMenuItemStyle}" IsCheckable="True">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Estado Envíos" VerticalAlignment="Center"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <Separator Visibility="Collapsed"/> <!-- Invisible separator to push tools to the right if needed, or just standard spacing -->

            <MenuItem Header="Herramientas" Style="{StaticResource ModernMenuItemStyle}" Margin="12,0,0,0">
                <MenuItem Header="Clientes excluidos" Style="{StaticResource ModernMenuItemStyle}">
                    <MenuItem.Icon>
                        <TextBlock Text="🚫" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                <MenuItem Header="Configuración SMTP" Style="{StaticResource ModernMenuItemStyle}">
                    <MenuItem.Icon>
                        <TextBlock Text="⚙" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Acerca de..." Style="{StaticResource ModernMenuItemStyle}">
                    <MenuItem.Icon>
                        <TextBlock Text="ℹ" FontSize="12"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ── Barra de estado inferior ── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource SurfaceAltBrush}"
                   BorderBrush="{StaticResource BorderLightBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="FACTURAEMAIL — CM Capital Markets · Ochandiano, 2 · 28023 Madrid"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:HH:mm}'}"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Contenido principal ── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ContentControl x:Name="MainContent">
                <views:ConsultaFacturasView/>
            </ContentControl>
        </ScrollViewer>
    </DockPanel>
</Window>
