<UserControl x:Class="FacturacionMail.Views.ConsultaFacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FacturacionMail.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1150"
             Background="{StaticResource AppBackgroundBrush}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
            </Border.Effect>
        </Border>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,20"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🔍" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Consulta de facturas"
                                   FontFamily="Segoe UI" FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="RANGO DE CLIENTES" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Desde:" VerticalAlignment="Center" Margin="0,0,8,4" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding ClienteDesde, UpdateSourceTrigger=PropertyChanged}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hasta:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding ClienteHasta, UpdateSourceTrigger=PropertyChanged}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock Text="RANGO DE FACTURAS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Desde:" VerticalAlignment="Center" Margin="0,0,8,4" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding FacturaDesde, UpdateSourceTrigger=PropertyChanged}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hasta:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding FacturaHasta, UpdateSourceTrigger=PropertyChanged}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <Rectangle Grid.Column="5" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="MES Y AÑO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding MesAnio, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource PrimaryDarkBrush}"
                                 TextAlignment="Center" Width="90"/>
                    </StackPanel>

                    <Rectangle Grid.Column="3" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}" Margin="0,0,22,0" VerticalAlignment="Center"/>

                    <StackPanel>
                        <TextBlock Text="TIPO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <StackPanel Margin="0,2,0,0">
                            <RadioButton Content="Actuales" Style="{StaticResource ModernRadioStyle}" IsChecked="{Binding SoloActuales}" Margin="0,0,0,6"/>
                            <RadioButton Content="Todas" Style="{StaticResource ModernRadioStyle}" IsChecked="{Binding SoloActuales, Converter={StaticResource InvertBool}}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LimpiarCriteriosCommand}"
                            Padding="12,6" Margin="0,0,8,0" ToolTip="Limpiar">
                        <TextBlock Text="↺" FontSize="15" Margin="0" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource DangerButtonStyle}"
                            Click="OnSalirClick"
                            Padding="12,6" Margin="0,0,12,0" ToolTip="Salir">
                        <TextBlock Text="✕" FontSize="12" Margin="0" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding ProcesarSeleccionCommand}"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Procesar" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,16,24,20"
              Visibility="{Binding ResultadosVisibles, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <ContentControl Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✉" FontSize="16" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Mensaje"
                                   FontFamily="Segoe UI" FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Añadir destinatario" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Background="{StaticResource SurfaceAltBrush}"
                                 Text="{Binding NuevaDireccion, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="9,6" FontSize="13"/>
                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38" Width="40"
                                FontSize="20" FontWeight="Bold"
                                Padding="0,0,0,2"
                                Command="{Binding InsertarDireccionCommand}"
                                ToolTip="Añadir a la lista"/>
                    </Grid>

                    <DataGrid Grid.Row="3"
                        ItemsSource="{Binding Direcciones}"
                        Style="{StaticResource ModernDataGridStyle}"
                        ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                        RowStyle="{StaticResource ModernDataGridRowStyle}"
                        BorderThickness="1"
                        BorderBrush="{StaticResource BorderLightBrush}"
                        RowHeight="35"
                        ColumnHeaderHeight="37"
                        Height="317"
                        Margin="0,0,0,16"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        GridLinesVisibility="None">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="46" CanUserSort="False">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox IsChecked="{Binding DataContext.SeleccionarTodasDirecciones, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              HorizontalAlignment="Center" ToolTip="Seleccionar todas" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="4" Text="ASUNTO" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="5"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding AsuntoEmail, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="9,6"
                             Background="{StaticResource SurfaceAltBrush}"
                             Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="6" Text="MENSAJE" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="7"
                             Style="{StaticResource ModernTextAreaStyle}"
                             Text="{Binding CuerpoEmail, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <Button Grid.Row="8"
                            Command="{Binding EnviarMailCommand}"
                            FontSize="14" Padding="32,10" HorizontalAlignment="Right">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Enviar Correo"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                <Setter Property="Text" Value="Enviando..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </Grid>
            </ContentControl>

            <ContentControl Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderThickness="0"
                            Padding="16,10"
                            CornerRadius="16,16,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#28627D" Offset="0"/>
                                <GradientStop Color="#3A7A96" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <TextBlock Text="FACTURAS ADJUNTAS A ENVIAR"
                                       Foreground="#FFFFFF"
                                       FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right"
                                    Background="#3A7A96" CornerRadius="10"
                                    Padding="10,2" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Facturas.Count}"
                                           Foreground="#FFFFFF"
                                           FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                        ItemsSource="{Binding Facturas}"
                        Style="{StaticResource ModernDataGridStyle}"
                        ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                        RowStyle="{StaticResource ModernDataGridRowStyle}"
                        BorderThickness="0"
                        GridLinesVisibility="None">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="75" CanUserSort="False">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox IsChecked="{Binding DataContext.SeleccionarTodasFacturas, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              HorizontalAlignment="Center" ToolTip="Seleccionar todas" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Archivo" Binding="{Binding NombreArchivo}" Width="*"/>
                            <DataGridTextColumn Header="Cliente" Binding="{Binding NombreCliente}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </ContentControl>
        </Grid>

        <Grid Grid.Row="2"
              Visibility="{Binding ResultadosVisibles, Converter={StaticResource InvertBoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                <TextBlock Text="📋" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Configura los criterios y pulsa"
                           FontFamily="Segoe UI" FontSize="16"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="▶  Procesar Selección"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="para cargar las facturas y gestionar el envío por email."
                           FontFamily="Segoe UI" FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>