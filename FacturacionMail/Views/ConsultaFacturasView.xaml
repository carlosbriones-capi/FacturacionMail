<UserControl x:Class="FacturacionMail.Views.ConsultaFacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FacturacionMail.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1150"
             Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Panel de filtros -->
            <RowDefinition Height="Auto"/>  <!-- Barra de estado -->
            <RowDefinition Height="*"/>     <!-- Zona de resultados (email + tablas) -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 0 — PANEL DE FILTROS                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,20,28,20">
            <Border.Effect>
                <DropShadowEffect Color="#A0AEC0" BlurRadius="10" ShadowDepth="3" Opacity="0.12"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- Label Criterios -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>   <!-- Clientes -->
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>   <!-- Facturas -->
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>   <!-- Mes-Año -->
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>   <!-- Tipo -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>   <!-- Botones -->
                </Grid.ColumnDefinitions>

                <!-- Título sección -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="CONSULTA DE"
                               FontFamily="Segoe UI" FontSize="9"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="Facturas"
                               FontFamily="Segoe UI" FontSize="22"
                               FontWeight="Light"
                               Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>

                <!-- Separador vertical -->
                <Rectangle Grid.Column="1" Width="1" Height="48"
                           Fill="{StaticResource BorderLightBrush}"
                           VerticalAlignment="Center"/>

                <!-- Rango Clientes -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="CLIENTES" Style="{StaticResource FormLabelStyle}" FontSize="10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="75"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Desde" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="Hasta" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,2"/>
                        <TextBox Grid.Row="2" Grid.Column="0"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding ClienteDesde, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding ClienteHasta, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Separador -->
                <Rectangle Grid.Column="3" Width="1" Height="48"
                           Fill="{StaticResource BorderLightBrush}"
                           VerticalAlignment="Center"/>

                <!-- Rango Facturas -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock Text="FACTURAS" Style="{StaticResource FormLabelStyle}" FontSize="10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="75"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Desde" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="Hasta" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="2,0,0,2"/>
                        <TextBox Grid.Row="2" Grid.Column="0"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding FacturaDesde, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding FacturaHasta, UpdateSourceTrigger=PropertyChanged}"
                                 TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Separador -->
                <Rectangle Grid.Column="5" Width="1" Height="48"
                           Fill="{StaticResource BorderLightBrush}"
                           VerticalAlignment="Center"/>

                <!-- Mes-Año -->
                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                    <TextBlock Text="FACTURACIÓN" Style="{StaticResource FormLabelStyle}" FontSize="10"/>
                    <TextBlock Text="Mes - Año" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="2,0,0,2"/>
                    <Border Background="{StaticResource PrimaryVeryLightBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="2" CornerRadius="6"
                            Padding="10,4" Width="90">
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding MesAnio, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16" FontWeight="Bold"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 TextAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"/>
                    </Border>
                </StackPanel>

                <!-- Separador -->
                <Rectangle Grid.Column="7" Width="1" Height="48"
                           Fill="{StaticResource BorderLightBrush}"
                           VerticalAlignment="Center"/>

                <!-- Tipo de Facturas -->
                <StackPanel Grid.Column="8" VerticalAlignment="Center">
                    <TextBlock Text="TIPO" Style="{StaticResource FormLabelStyle}" FontSize="10"/>
                    <RadioButton Content="Actuales"
                                 Style="{StaticResource ModernRadioStyle}"
                                 IsChecked="{Binding SoloActuales}"
                                 Margin="0,6,0,0"/>
                    <RadioButton Content="Todas"
                                 Style="{StaticResource ModernRadioStyle}"
                                 IsChecked="{Binding SoloActuales, Converter={StaticResource InvertBool}}"
                                 Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Botones -->
                <StackPanel Grid.Column="10"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button Content="↺  Limpiar"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LimpiarCriteriosCommand}"
                            Padding="16,10" Margin="0,0,10,0"/>
                    <Button Content="✕  Salir"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="OnSalirClick"
                            Padding="16,10" Margin="0,0,14,0"/>
                    <Button Content="▶  Procesar Selección"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ProcesarSeleccionCommand}"
                            Padding="20,10"
                            FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 1 — BARRA DE ESTADO                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Visibility="{Binding MensajeEstado, Converter={StaticResource StringToVisibility}}"
                Padding="28,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource PrimaryVeryLightBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Ocupado}" Value="True">
                            <Setter Property="Background" Value="#FFF3CD"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True"
                             Visibility="{Binding Ocupado, Converter={StaticResource BoolToVisibility}}"
                             Width="100" Height="6"
                             Margin="0,0,14,0"
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="Transparent"/>
                <TextBlock Text="{Binding MensajeEstado}"
                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                    <Setter Property="Foreground" Value="#856404"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ROW 2 — ZONA DE RESULTADOS (visible solo tras Procesar)         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Visibility="{Binding ResultadosVisibles, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Panel email -->
                <RowDefinition Height="*"/>    <!-- Tablas -->
            </Grid.RowDefinitions>

            <!-- ── Panel email ─────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Asunto -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📌  ASUNTO DEL EMAIL"
                                   Style="{StaticResource SectionTitleStyle}"
                                   FontSize="10" Margin="0,0,0,8"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding AsuntoEmail, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13"/>
                    </StackPanel>

                    <!-- Cuerpo -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="📝  CUERPO DEL MAIL"
                                   Style="{StaticResource SectionTitleStyle}"
                                   FontSize="10" Margin="0,0,0,8"/>
                        <Border BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1.5" CornerRadius="5"
                                Background="{StaticResource SurfaceAltBrush}">
                            <TextBox Text="{Binding CuerpoEmail, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="60"
                                     VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0" Padding="10,6"
                                     FontFamily="Consolas" FontSize="12"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Botón Envía Mail -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <Button Command="{Binding EnviarMailCommand}"
                                Padding="22,14"
                                FontSize="14">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✉" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Enviar Mail"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                    <Setter Property="Text" Value="Enviando..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Tablas ─────────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.8*"/>
                </Grid.ColumnDefinitions>

                <!-- Tabla Direcciones -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{StaticResource HeaderGradientBrush}"
                                CornerRadius="10,10,0,0" Padding="16,12">
                            <DockPanel>
                                <TextBlock Text="📧  DIRECCIONES DE ENVÍO"
                                           Foreground="White"
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <Border DockPanel.Dock="Right"
                                        Background="White" CornerRadius="12"
                                        Padding="8,2" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Direcciones.Count}"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DockPanel>
                        </Border>

                        <!-- Grid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Direcciones}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  CellStyle="{StaticResource ModernDataGridCellStyle}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Sel" Width="50" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}"  Width="1.5*"/>
                                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Inserta Dirección -->
                        <Border Grid.Row="2"
                                Background="#F7FAFC"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="0,1,0,0"
                                CornerRadius="0,0,12,12"
                                Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="AÑADIR DIRECCIÓN"
                                           Style="{StaticResource SectionTitleStyle}"
                                           FontSize="10" Margin="2,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource ModernTextBoxStyle}"
                                             Background="White"
                                             Text="{Binding NuevaDireccion, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="2"
                                            Content="+"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Padding="16,8" FontSize="20" FontWeight="Bold"
                                            Command="{Binding InsertarDireccionCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Tabla Facturas -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                Background="{StaticResource HeaderGradientBrush}"
                                CornerRadius="10,10,0,0" Padding="16,12">
                            <DockPanel>
                                <TextBlock Text="🧾  FACTURAS A ENVIAR"
                                           Foreground="White"
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <Border DockPanel.Dock="Right"
                                        Background="White" CornerRadius="12"
                                        Padding="8,2" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Facturas.Count}"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DockPanel>
                        </Border>

                        <!-- Grid -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Facturas}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  CellStyle="{StaticResource ModernDataGridCellStyle}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Sel" Width="46" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Nº Factura" Binding="{Binding NumeroFactura}" Width="90"/>
                                <DataGridTextColumn Header="Archivo"    Binding="{Binding NombreArchivo}"  Width="110"/>
                                <DataGridTextColumn Header="Cliente"    Binding="{Binding NombreCliente}"  Width="*"/>
                                <DataGridTemplateColumn Header="Importe" Width="115">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Importe, StringFormat='{}{0:N2} €'}"
                                                       TextAlignment="Right"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Mes-Año" Binding="{Binding MesAnio}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- ESTADO VACÍO — visible cuando no se han procesado facturas      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Visibility="{Binding ResultadosVisibles, Converter={StaticResource InvertBoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                <TextBlock Text="📋" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Configura los criterios y pulsa"
                           FontFamily="Segoe UI" FontSize="16"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="▶  Procesar Selección"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="para cargar las facturas y gestionar el envío por email."
                           FontFamily="Segoe UI" FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
