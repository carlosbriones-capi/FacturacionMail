<UserControl x:Class="FacturacionMail.Views.ConsultaFacturasView"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FacturacionMail.ViewModels"
             xmlns:views="clr-namespace:FacturacionMail.Views"
             xmlns:local="clr-namespace:FacturacionMail"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1150"
             Background="{StaticResource AppBackgroundBrush}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
        <local:BindingProxy x:Key="Proxy" Data="{Binding}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
            </Border.Effect>
        </Border>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,20"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="🔍" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Consulta de facturas"
                                   FontFamily="{StaticResource HeaderFontFamily}" FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="RANGO DE CLIENTES" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Desde:" VerticalAlignment="Center" Margin="0,0,8,4" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding ClienteDesde, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericString}}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hasta:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding ClienteHasta, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericString}}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock Text="RANGO DE FACTURAS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Desde:" VerticalAlignment="Center" Margin="0,0,8,4" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding FacturaDesde, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericString}}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center" Margin="0,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Hasta:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernTextBoxStyle}" 
                            Text="{Binding FacturaHasta, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericString}}" 
                            Width="110" Height="33" Padding="4,2" TextAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <Rectangle Grid.Column="5" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="MES Y AÑO" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding MesAnio, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{StaticResource PrimaryDarkBrush}"
                                 TextAlignment="Center" Width="90"/>
                    </StackPanel>


                </StackPanel>

                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LimpiarCriteriosCommand}"
                            Padding="12,6" Margin="0,0,8,0" ToolTip="Limpiar">
                        <TextBlock Text="↺" FontSize="15" Margin="0" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding ProcesarSeleccionCommand}"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Procesar" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="24,4,24,20"
              Visibility="{Binding ResultadosVisibles, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <ContentControl Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20" VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="✉" FontSize="16" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Mensaje"
                                   FontFamily="{StaticResource HeaderFontFamily}" FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Añadir destinatario" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding EmailForm.NuevaDireccion, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="9,6" FontSize="13"/>
                        <Button Grid.Column="2"
                                Content="+"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38" Width="40"
                                FontSize="20" FontWeight="Bold"
                                Padding="0,0,0,2"
                                Command="{Binding EmailForm.InsertarDireccionCommand}"
                                ToolTip="Añadir a la lista"/>
                    </Grid>

                    <DataGrid Grid.Row="3" ItemsSource="{Binding Direcciones}"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              BorderThickness="1"
                              BorderBrush="{StaticResource BorderLightBrush}"
                              RowHeight="35"
                              ColumnHeaderHeight="37"
                              Height="220"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              GridLinesVisibility="None"
                              Margin="0,0,0,16">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="55" CanUserSort="False" HeaderStyle="{StaticResource ModernCheckBoxColumnHeaderStyle}">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox IsChecked="{Binding Data.SeleccionarTodasDirecciones, Source={StaticResource Proxy}}"
                                              HorizontalAlignment="Center" ToolTip="Seleccionar todas" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="4" Text="Asunto" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="5"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding EmailForm.AsuntoEmail, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="9,6"
                             Margin="0,0,0,16"/>

                    <TextBlock Grid.Row="6" Text="Mensaje" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="7"
                             Style="{StaticResource ModernTextAreaStyle}"
                             Text="{Binding EmailForm.CuerpoEmail, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <Button Grid.Row="8"
                            Command="{Binding EnviarMailCommand}"
                            FontSize="14" Padding="32,10" HorizontalAlignment="Right">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Enviar Correo"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                <Setter Property="Text" Value="Enviando..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </Grid>
            </ContentControl>

            <ContentControl Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20" VerticalAlignment="Top">
                <DockPanel>
                    <!-- Cabecera de la lista (Matching modern style) -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📄" FontSize="15" Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Facturas Adjuntas a Enviar"
                                       FontFamily="{StaticResource HeaderFontFamily}" FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}"
                                CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Facturas.Count}"
                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Facturas}"
                              Style="{StaticResource ModernDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                              RowStyle="{StaticResource ModernDataGridRowStyle}"
                              BorderThickness="1"
                              BorderBrush="{StaticResource BorderLightBrush}"
                              GridLinesVisibility="None"
                              RowHeight="36"
                              MaxHeight="550"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ColumnHeaderHeight="38">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="75" CanUserSort="False" HeaderStyle="{StaticResource ModernCheckBoxColumnHeaderStyle}">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox IsChecked="{Binding Data.SeleccionarTodasFacturas, Source={StaticResource Proxy}}"
                                              HorizontalAlignment="Center" ToolTip="Seleccionar todas" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Nº Factura" Binding="{Binding NumeroFactura}" Width="*"/>
                            <DataGridTemplateColumn Header="Ver" Width="60" CanUserSort="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource BorderlessButtonStyle}"
                                                Command="{Binding DataContext.VisualizarFacturaCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Ver PDF"
                                                Padding="2"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </ContentControl>
        </Grid>

        <Grid Grid.Row="2"
              Visibility="{Binding ResultadosVisibles, Converter={StaticResource InvertBoolToVisibility}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                <TextBlock Text="📋" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Configura los criterios y pulsa"
                           FontFamily="{StaticResource HeaderFontFamily}" FontSize="16"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="▶  Procesar"
                           FontFamily="{StaticResource HeaderFontFamily}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="para cargar las facturas y gestionar el envío por email."
                           FontFamily="{StaticResource HeaderFontFamily}" FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>