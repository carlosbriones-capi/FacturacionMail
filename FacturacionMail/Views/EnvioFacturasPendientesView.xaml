<UserControl x:Class="FacturacionMail.Views.EnvioFacturasPendientesView"
             x:Name="root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:FacturacionMail.ViewModels"
             xmlns:views="clr-namespace:FacturacionMail.Views"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1150"
             Background="{StaticResource AppBackgroundBrush}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.DataContext>
        <vm:EnvioFacturasPendientesViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Panel superior: selección de cliente y lista ── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
            </Border.Effect>
        </Border>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,20"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Título -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="📨" FontSize="14" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Envío de Facturas Pendientes"
                                   FontFamily="Segoe UI" FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center"/>

                <!-- Selector de cliente -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="CLIENTE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                              Width="240"
                              IsEditable="True"
                              TextSearch.TextPath="Codigo"
                              ItemsSource="{Binding Clientes}"
                              SelectedItem="{Binding ClienteSeleccionado, Mode=TwoWay}"
                              IsEnabled="{Binding Ocupado, Converter={StaticResource InvertBool}}">
                        <ComboBox.ItemTemplate>

                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Codigo}" Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" Width="36" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Separador + Selector de lista (visible solo cuando hay listas) -->
                <Rectangle Grid.Column="3" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}" VerticalAlignment="Center"
                           Visibility="{Binding ListasVisibles, Converter={StaticResource BoolToVisibility}}"/>

                <StackPanel Grid.Column="4" VerticalAlignment="Center"
                            Visibility="{Binding ListasVisibles, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="LISTA DE ENVÍO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <ComboBox Style="{StaticResource ModernComboBoxStyle}"
                              Width="220"
                              ItemsSource="{Binding Listas}"
                              SelectedItem="{Binding ListaSeleccionada, Mode=TwoWay}"
                              DisplayMemberPath="Nombre"
                              IsEnabled="{Binding Ocupado, Converter={StaticResource InvertBool}}"/>
                </StackPanel>

                <!-- Mensaje de estado (inline) -->
                <TextBlock Grid.Column="5"
                           Text="{Binding MensajeEstado}"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="16,0"/>

                <!-- Botones -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LimpiarCommand}"
                            Padding="12,6" Margin="0,0,8,0" ToolTip="Limpiar selección">
                        <TextBlock Text="↺" FontSize="15" Margin="0" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding EnviarMailCommand}"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Enviar Correo"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                <Setter Property="Text" Value="Enviando..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Contenido principal ── -->
        <Grid Grid.Row="1">

            <!-- Estado vacío — sin cliente seleccionado -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"
                        Visibility="{Binding DetalleVisible, Converter={StaticResource InvertBoolToVisibility}}">
                <TextBlock Text="🏢" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Selecciona un cliente"
                           FontFamily="Segoe UI" FontSize="16"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="y elige una lista de envío"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="para ver los destinatarios y las facturas pendientes."
                           FontFamily="Segoe UI" FontSize="14"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Panel de resultados — dos columnas -->
            <Grid Margin="24,0,24,20"
                  Visibility="{Binding DetalleVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Columna izquierda: Destinatarios ── -->
<ContentControl Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header destinatarios -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="✉" FontSize="16"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Nuevo Mensaje"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="Añadir destinatario" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>

                        <!-- Nombre de la lista seleccionada -->
                        <Border Grid.Row="2"
                            Background="{StaticResource SurfaceAltBrush}"
                            CornerRadius="8" Padding="12,8"
                            Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ListaSeleccionada.Nombre}"
                                    FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryDarkBrush}"
                                    VerticalAlignment="Center"/>
                                <Border Background="{StaticResource PrimaryLightBrush}"
                                    CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Direcciones.Count}"
                                        Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Background="{StaticResource SurfaceAltBrush}"
                                     Text="{Binding NuevaDireccion, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="9,6" FontSize="13"/>
                            <Button Grid.Column="2"
                                    Content="+"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Height="38" Width="42"
                                    FontSize="20" FontWeight="Bold"
                                    Padding="0,0,0,2"
                                    Command="{Binding InsertarDireccionCommand}"
                                    ToolTip="Añadir manual"/>
                        </Grid>

                        

                        <DataGrid Grid.Row="4" ItemsSource="{Binding Direcciones}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderLightBrush}"
                                  Height="220"
                                  RowHeight="36"
                                  ColumnHeaderHeight="38"
                                  GridLinesVisibility="None"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="55" CanUserSort="False">
                                    <DataGridTemplateColumn.Header>
                                        <CheckBox HorizontalAlignment="Center" ToolTip="Seleccionar todos"
                                                  IsChecked="{Binding DataContext.SeleccionarTodasDirecciones,
                                                      RelativeSource={RelativeSource AncestorType={x:Type views:EnvioFacturasPendientesView}}}"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Separator Grid.Row="5" Height="1" Background="{StaticResource BorderLightBrush}" Margin="0,16"/>

                        <TextBlock Grid.Row="6" Text="Asunto" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                        <TextBox Grid.Row="7"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding AsuntoEmail, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="9,6"
                                 Background="{StaticResource SurfaceAltBrush}"
                                 Margin="0,0,0,16"/>

                        <TextBlock Grid.Row="8" Text="Mensaje" Style="{StaticResource FormLabelStyle}" Margin="0,0,0,4"/>
                        <TextBox Grid.Row="9"
                                 Style="{StaticResource ModernTextAreaStyle}"
                                 Text="{Binding CuerpoEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Height="100"
                                 Margin="0,0,0,16"/>

                        <Button Grid.Row="10"
                                Command="{Binding EnviarMailCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="32,10" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✉" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Enviar Correo"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                    <Setter Property="Text" Value="Enviando..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </ContentControl>

                <!-- ── Columna derecha: Facturas pendientes ── -->
                <ContentControl Grid.Row="0" Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20">
                    <DockPanel>
                        <!-- Header facturas -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📄" FontSize="15"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Facturas Pendientes"
                                       FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="{StaticResource PrimaryLightBrush}"
                                    CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Facturas.Count}"
                                           Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- Nombre del cliente -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="8" Padding="12,8"
                                Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏢" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryDarkBrush}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} — {1}">
                                            <Binding Path="ClienteSeleccionado.Codigo"/>
                                            <Binding Path="ClienteSeleccionado.Nombre"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid facturas -->
                        <DataGrid ItemsSource="{Binding Facturas}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  BorderThickness="0"
                                  RowHeight="36"
                                  ColumnHeaderHeight="38"
                                  GridLinesVisibility="None"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="55" CanUserSort="False">
                                    <DataGridTemplateColumn.Header>
                                        <CheckBox HorizontalAlignment="Center" ToolTip="Seleccionar todas"
                                                  IsChecked="{Binding DataContext.SeleccionarTodasFacturas,
                                                          RelativeSource={RelativeSource AncestorType={x:Type views:EnvioFacturasPendientesView}}}"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Seleccionada, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Archivo"     Binding="{Binding NombreArchivo}"   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </ContentControl>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
