<UserControl x:Class="FacturacionMail.Views.FacturacionMailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:FacturacionMail.ViewModels"
             xmlns:local="clr-namespace:FacturacionMail"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1150"
             Background="{StaticResource AppBackgroundBrush}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <UserControl.Resources>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header (Matching ConsultaFacturasView structure) ── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
            </Border.Effect>
        </Border>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="24,18"
                Margin="0,0,0,12"
                CornerRadius="0,0,12,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Título -->
                    <ColumnDefinition Width="32"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Mes-Año -->
                    <ColumnDefinition Width="32"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Selección -->
                    <ColumnDefinition Width="32"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Modo Envío -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer flexible -->
                    <ColumnDefinition Width="Auto"/> <!-- Acciones -->
                </Grid.ColumnDefinitions>

                <!-- Título -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="✉" FontSize="15" Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Facturación Mail"
                                   FontFamily="{StaticResource HeaderFontFamily}" FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Center"/>

                <!-- Mes-Año -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="MES Y AÑO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource ModernTextBoxStyle}"
                             Text="{Binding MesAnio, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{StaticResource PrimaryDarkBrush}"
                             TextAlignment="Center" Width="90"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Center"/>

                <!-- Selección (Pill horizontal) -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock Text="SELECCIÓN" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Marcar Todos"
                                         Style="{StaticResource ModernPillRadioStyle}"
                                         IsChecked="{Binding SeleccionarTodo}"
                                         Margin="0,0,2,0"/>
                            <RadioButton Content="Desmarcar Todos"
                                         Style="{StaticResource ModernPillRadioStyle}"
                                         IsChecked="{Binding SeleccionarTodo, Converter={StaticResource InvertBool}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Rectangle Grid.Column="5" Width="1" Height="40" Fill="{StaticResource BorderLightBrush}" HorizontalAlignment="Center"/>

                <!-- Modo Envío (Pill horizontal) -->
                <StackPanel Grid.Column="6" VerticalAlignment="Center">
                    <TextBlock Text="MODO ENVÍO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="10" Padding="3">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Mensual"
                                         Style="{StaticResource ModernPillRadioStyle}"
                                         IsChecked="{Binding IsDetailedMode, Converter={StaticResource InvertBool}}"
                                         Margin="0,0,2,0"/>
                            <RadioButton Content="Detallado"
                                         Style="{StaticResource ModernPillRadioStyle}"
                                         IsChecked="{Binding IsDetailedMode}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Acciones -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding InicializaCriteriosCommand}"
                            Padding="12,6" Margin="0,0,8,0"
                            ToolTip="Inicializar criterios"
                            Visibility="{Binding IsDetailedMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="↺" FontSize="15" Margin="0" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Contenido Principal ── -->
        <Grid Grid.Row="1" Margin="24,4,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Panel Izquierdo: Lista de Clientes ─── -->
            <ContentControl Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20" VerticalAlignment="Stretch">
                <DockPanel>
                    <!-- Cabecera de la lista -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="15" Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Destinatarios"
                                       FontFamily="{StaticResource HeaderFontFamily}" FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="{StaticResource PrimaryLightBrush}"
                                CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Clientes.Count, StringFormat='{}Total: {0}'}"
                                       Foreground="White" FontSize="11" FontWeight="Bold"/>
                        </Border>

                        <!-- Buscador -->
                        <Grid Grid.Column="3">
                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="30,7,8,7"/>
                            <TextBlock Text="🔍" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" Margin="10,0,0,0"
                                       VerticalAlignment="Center" HorizontalAlignment="Left"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </Grid>

                    <!-- DataGrid con Scroll Limit y bordes redondeados -->
                    <Border BorderBrush="{StaticResource BorderLightBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding ClientesView}"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  MaxHeight="637"
                                  ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                  RowStyle="{StaticResource ModernDataGridRowStyle}"
                                  BorderThickness="0"
                                  GridLinesVisibility="None"
                                  RowHeight="36"
                                  ColumnHeaderHeight="38"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource ModernDataGridCellStyle}">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="60" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.Header>
                                        <TextBlock Text="Envío" HorizontalAlignment="Center"/>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Código" Binding="{Binding Cliente.Codigo}"
                                                    Width="*" ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                                <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nombre}"
                                                    Width="*" ElementStyle="{StaticResource {x:Type TextBlock}}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </ContentControl>

            <!-- ─── Panel Derecho: Configuración Correo ─── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Card Subject -->
                <ContentControl Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="⚙" FontSize="15" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Asunto del Correo"
                                       FontFamily="{StaticResource HeaderFontFamily}" FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding AsuntoEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,8" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </ContentControl>

                <!-- Card Body -->
                <ContentControl Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📝" FontSize="15" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cuerpo del Mensaje"
                                       FontFamily="{StaticResource HeaderFontFamily}" FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBox Grid.Row="1" Style="{StaticResource DynamicBodyTextBoxStyle}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Hidden"
                                 Margin="0,0,0,20"/>

                        <Button Grid.Row="2"
                                Command="{Binding EnviarMailCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="32,10" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✉" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Enviar Correo"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                    <Setter Property="Text" Value="Enviando..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
